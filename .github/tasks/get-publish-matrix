#!/usr/bin/env bash

set -euo pipefail

payload_arg="${1:-}"
base="${2:-}"
head="${3:-}"

if [[ "${payload_arg}" == @* ]]; then
  payload="$(cat "${payload_arg#@}")"
else
  payload="${payload_arg}"
fi

jq -e 'type == "object"' >/dev/null <<<"${payload}"
[[ -n "${base}" && -n "${head}" ]] || { echo "Missing base/head ref" >&2; exit 1; }

affected="$(MOON_BASE="${base}" MOON_HEAD="${head}" moon query projects --affected)"
jq -c '
  [
    .projects[]
    | select((.tasks // {}) | has("publish"))
    | {target: .id}
  ]
  | sort_by(.target)
' <<<"${affected}"
