#!/usr/bin/env bash

set -euo pipefail

target="${1:-}"
channel="${2:-}"
source_branch="${3:-}"
run_attempt="${4:-}"

[[ -n "${target}" ]] || { echo "Missing publish target" >&2; exit 1; }
case "${channel}" in
  next|latest) ;;
  *) echo "Unsupported publish channel '${channel}'" >&2; exit 1 ;;
esac
case "${source_branch}" in
  main|release/*) ;;
  *) echo "Unsupported source branch '${source_branch}'" >&2; exit 1 ;;
esac
[[ "${run_attempt}" =~ ^[1-9][0-9]*$ ]] || { echo "Invalid run attempt '${run_attempt}'" >&2; exit 1; }

projects_json="$(moon query projects)"
project="$(jq -c --arg target "${target}" 'first(.projects[] | select(.id == $target)) // empty' <<<"${projects_json}")"
[[ -n "${project}" ]] || { echo "Unknown Moon target '${target}'" >&2; exit 1; }
jq -e '(.tasks // {}) | has("publish")' >/dev/null <<<"${project}" || {
  echo "Moon target '${target}' is not publishable" >&2
  exit 1
}

source="$(jq -r '.source // empty' <<<"${project}")"
[[ -n "${source}" ]] || { echo "Moon target '${target}' has no source" >&2; exit 1; }

if [[ -f "${source}/package.json" ]]; then
  current_version="$(jq -r '.version // empty' "${source}/package.json")"
elif [[ -f "${source}/Cargo.toml" ]]; then
  source_abs="$(realpath "${source}")"
  current_version="$(
    cargo metadata --no-deps --format-version 1 --manifest-path "${source}/Cargo.toml" |
      jq -r --arg source "${source_abs}" '
        first(
          .packages[]
          | select((.manifest_path | sub("/Cargo.toml$"; "")) == $source)
          | .version
        ) // empty
      '
  )"
else
  echo "Unsupported version source for Moon target '${target}' at '${source}'" >&2
  exit 1
fi

if [[ ! "${current_version}" =~ ^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)$ ]]; then
  echo "Malformed semantic version '${current_version}' for Moon target '${target}'; stable version required" >&2
  exit 1
fi
major="${BASH_REMATCH[1]}"
minor="${BASH_REMATCH[2]}"
patch="${BASH_REMATCH[3]}"

latest_stable_tag() {
  local prefix="$1"
  git tag --merged HEAD --list "${prefix}*" |
    awk -v prefix="${prefix}" '
      index($0, prefix) == 1 {
        version = substr($0, length(prefix) + 1)
        if (version ~ /^[0-9]+\.[0-9]+\.[0-9]+$/) print version "\t" $0
      }
    ' |
    sort -t $'\t' -k1,1V |
    tail -n 1 |
    cut -f 2-
}

stable_tag="$(latest_stable_tag "${target}-v")"
if [[ -z "${stable_tag}" ]]; then
  stable_tag="$(latest_stable_tag "${source}-v")"
fi
if [[ -n "${stable_tag}" ]]; then
  commit_distance="$(git rev-list --first-parent --count "${stable_tag}..HEAD")"
else
  commit_distance="$(git rev-list --first-parent --count HEAD)"
fi

if [[ "${channel}" == latest ]]; then
  version="${current_version}"
elif [[ "${source_branch}" == main ]]; then
  version="${major}.$((minor + 1)).0-next.${commit_distance}.${run_attempt}"
else
  version="${major}.${minor}.$((patch + 1))-next.${commit_distance}.${run_attempt}"
fi
release_tag="${target}-v${version}"

jq -n \
  --arg target "${target}" \
  --arg source "${source}" \
  --arg component "${target}" \
  --arg current_version "${current_version}" \
  --arg stable_tag "${stable_tag}" \
  --argjson commit_distance "${commit_distance}" \
  --arg version "${version}" \
  --arg release_tag "${release_tag}" \
  '{
    target: $target,
    source: $source,
    component: $component,
    current_version: $current_version,
    stable_tag: $stable_tag,
    commit_distance: $commit_distance,
    version: $version,
    release_tag: $release_tag
  }'
